#!/usr/bin/env bash
# Running instances with AMI name and creation date
set -euo pipefail

instances=$(aws ec2 describe-instances \
  --filters "Name=instance-state-name,Values=running" \
  --output json)

ami_ids=$(echo "$instances" | jq -r '[.Reservations[].Instances[].ImageId] | unique | .[]')

if [[ -z "$ami_ids" ]]; then
  echo "No running instances found."
  exit 0
fi

# shellcheck disable=SC2086
images=$(aws ec2 describe-images --image-ids $ami_ids --output json)

(echo -e "InstanceName\tInstanceId\tAMI_ID\tAMI_Name\tAMI_Created"
jq -r --argjson imgs "$images" '
  ($imgs.Images | map({(.ImageId): {n:.Name, d:.CreationDate}}) | add) as $m |
  .Reservations[].Instances[] |
  [(.Tags//[]|map(select(.Key=="Name"))|.[0].Value//"N/A"),
   .InstanceId, .ImageId, ($m[.ImageId].n//"N/A"), ($m[.ImageId].d//"N/A")]|@tsv
' <<< "$instances" | sort -k3) | column -t -s $'\t'
