#!/usr/bin/env bash
# ECS clusters and service status
set -euo pipefail

clusters=$(aws ecs list-clusters --query 'clusterArns[]' --output text)

if [[ -z "$clusters" ]]; then
  echo "No ECS clusters found."
  exit 0
fi

(echo -e "Cluster\tService\tDesired\tRunning\tStatus"
for arn in $clusters; do
  cluster=$(basename "$arn")
  services=$(aws ecs list-services --cluster "$cluster" --query 'serviceArns[]' --output text)
  [[ -z "$services" ]] && continue
  # shellcheck disable=SC2086
  aws ecs describe-services --cluster "$cluster" --services $services \
    --query 'services[*].[clusterArn,serviceName,desiredCount,runningCount,status]' \
    --output text | while IFS=$'\t' read -r c svc desired running status; do
      echo -e "$(basename "$c")\t$svc\t$desired\t$running\t$status"
    done
done) | column -t -s $'\t'
