#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to get the real script location
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

# Version info
VERSION="$(cat "$ROOT_DIR/VERSION" 2>/dev/null || echo 'dev')"

# Auto-deploy commands if missing (handles upgrade from older versions)
if [[ -d "$ROOT_DIR/examples/commands" && ! -d "$ROOT_DIR/commands/aws" ]]; then
  mkdir -p "$ROOT_DIR/commands/aws" "$ROOT_DIR/commands/ssm"
  command -v rsync >/dev/null 2>&1 && {
    rsync -a "$ROOT_DIR/examples/commands/aws/" "$ROOT_DIR/commands/aws/"
    rsync -a "$ROOT_DIR/examples/commands/ssm/" "$ROOT_DIR/commands/ssm/"
  } || {
    cp -a "$ROOT_DIR/examples/commands/aws/"* "$ROOT_DIR/commands/aws/"
    cp -a "$ROOT_DIR/examples/commands/ssm/"* "$ROOT_DIR/commands/ssm/"
  }
fi

# Core
source "$ROOT_DIR/lib/core/logging.sh"
source "$ROOT_DIR/lib/core/flags.sh"
source "$ROOT_DIR/lib/core/tty.sh"

# Menu
source "$ROOT_DIR/lib/menu/index.sh"

# AWS Auth
source "$ROOT_DIR/lib/core/aws_auth.sh"

# AWS Helpers
source "$ROOT_DIR/lib/core/aws.sh"
source "$ROOT_DIR/lib/core/commands.sh"
source "$ROOT_DIR/lib/aws/ec2.sh"
source "$ROOT_DIR/lib/aws/ssm.sh"

# Commands
source "$ROOT_DIR/lib/commands/ssm_login.sh"
source "$ROOT_DIR/lib/commands/ssm_connect.sh"
source "$ROOT_DIR/lib/commands/ssm_list.sh"
source "$ROOT_DIR/lib/commands/ssm_kill.sh"
source "$ROOT_DIR/lib/commands/ssm_exec.sh"
source "$ROOT_DIR/lib/commands/ssm_run.sh"
source "$ROOT_DIR/lib/commands/ssm_creds.sh"
source "$ROOT_DIR/lib/commands/ssm_config.sh"
source "$ROOT_DIR/lib/commands/ssm_update.sh"

usage() {
  cat <<EOF
Usage: ssm <command> [options]

AWS Systems Manager (SSM) session management tool

Commands:
  login      Authenticate with AWS via Granted (assume)
  connect    Start SSM shell session or port forwarding to an instance
  exec       Run a shell command on one or more instances via SSM
  run        Run a command or script against one or more AWS profiles
  creds      Manage AWS credentials (store/use)
  list       List active SSM sessions on this host
  kill       Terminate active SSM sessions
  config     Show current configuration, paths, and environment variables
  update     Update aws-ssm-tools to the latest version or a specific release

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

Run 'ssm <command> --help' for more information on a specific command.
EOF
}

main() {
  local cmd="${1:-}"
  
  # Handle version flag
  if [[ "$cmd" == "-v" ]] || [[ "$cmd" == "--version" ]]; then
    echo "aws-ssm-tools version $VERSION"
    exit 0
  fi
  
  # Handle help or no command
  if [[ -z "$cmd" ]] || [[ "$cmd" == "-h" ]] || [[ "$cmd" == "--help" ]]; then
    usage
    [[ -z "$cmd" ]] && exit 1 || exit 0
  fi
  
  shift || true

  case "$cmd" in
    login)
      ssm_login "$@"
      ;;
    connect)
      ssm_connect "$@"
      ;;
    exec)
      ssm_exec "$@"
      ;;
    run)
      ssm_run "$@"
      ;;
    creds)
      ssm_creds "$@"
      ;;
    list)
      ssm_list "$@"
      ;;
    kill)
      ssm_kill "$@"
      ;;
    config)
      ssm_config "$@"
      ;;
    update)
      ssm_update "$@"
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      exit 1
      ;;
  esac
}

main "$@"
